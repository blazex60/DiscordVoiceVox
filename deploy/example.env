# インスタンス設定ファイルのサンプル。
# /etc/discordbot/<インスタンス名>.env として配置する。
# 例: /etc/discordbot/zundamon-c0.env

# このbotのプロジェクトディレクトリ(botごとに異なる)
BOT_DIR=/home/zundamon/DiscordVoiceVox
# このbotの venv の python(botごとに異なる)
VENV_PYTHON=/home/zundamon/DiscordVoiceVox/.venv/bin/python

# クラスタ設定
CLUSTER_ID=0
CLUSTER_COUNT=4
# 全シャード数を固定(全クラスタ・全VPSで必ず同じ値にする)。
# 未設定ならDiscordから自動取得。本番は明示推奨。テストは小さい値(例4)。
# TOTAL_SHARDS=160

# 既存の .env をそのまま使う場合、DISCORD_TOKEN 等はそちらで設定済みでOK。
# ここに直接書いてもよい(例):
# DISCORD_TOKEN=xxxxx
