# ============================================================
# Per-instance environment variable template
#
# For each bot instance, copy this file and rename it:
#   cp env/bot.env.example env/bot-main.env   # /root/DiscordVoiceVox
#   cp env/bot.env.example env/bot-c.env      # /home/len/DiscordVoiceVox-c
#   cp env/bot.env.example env/bot-d.env      # /home/len/DiscordVoiceVox-d
#   cp env/bot.env.example env/bot-e.env      # /home/len/DiscordVoiceVox-e
#   cp env/bot.env.example env/bot-z.env      # /home/len/DiscordVoiceVox-z
#   cp env/bot.env.example env/bot-h.env      # /home/len/DiscordVoiceVox-h
#
# Then fill in BOT_TOKEN and BOT_NICKNAME for each instance.
# All other values can remain as-is when using docker-compose.
# ============================================================

# ---- Required: differs per instance ----
BOT_TOKEN=your_discord_bot_token_here
BOT_NICKNAME=ずんだもんβ

# ---- Database (Docker Compose サービス名で到達) ----
DB_HOST=postgres
DB_PORT=5432
DB_NAME=postgres
DB_USER=postgres
DB_PASS=your_db_password

# ---- TTS engines (Docker Compose サービス名で到達) ----
VOICEVOX_HOST=voicevox-engine:50021
VOICEVOX_HOSTS=voicevox-engine:50021
VOICEVOX_QUERY_HOST=voicevox-engine:50021
COEIROINK_HOST=127.0.0.1:50032
SHAREVOX_HOST=127.0.0.1:50025
AIVOICE_HOST=127.0.0.1:8001
AIVIS_HOST=127.0.0.1:8001
AQUES_HOST=127.0.0.1:8001

# ---- Lavalink ----
# NOTE: Do NOT include the http:// scheme — the URL parser splits on ":" directly.
# Correct:   LAVALINK_HOST=lavalink:2333
# Incorrect: LAVALINK_HOST=http://lavalink:2333
LAVALINK_HOST=lavalink:2333
LAVALINK_PASSWORD=change_me_lavalink_password

# ---- Optional ----
IS_GPU=False
START_TIME=21:00
END_TIME=02:00
GPU_HOST=
USAGE_LIMIT_PRICE=0
GLOBAL_DICT_CHECK=True
EEW_WEBHOOK_URL=
LAVALINK_UPLOADER=
SENTRY_DSN=
